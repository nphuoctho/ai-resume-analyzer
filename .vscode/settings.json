{
	// Set Biome as the default formatter for supported languages
	"editor.defaultFormatter": "biomejs.biome",

	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},

	// Use Prettier for CSS and Tailwind CSS files
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[tailwindcss]": {
		"editor.defaultFormatter": "biomejs.biome"
	},

	// Enable format on save
	"editor.formatOnSave": true,

	// Run code actions (organize imports, quick fixes) on save
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "explicit",
		"source.fixAll.biome": "explicit"
	},

	// Ensure a biome.json file is present for the extension to activate
	"biome.requireConfiguration": true,

	// Associate .css files with Tailwind CSS syntax highlighting
	"files.associations": {
		"*.css": "tailwindcss"
	}
}
